# pyenv
#   For a library or app, you might want to share your .python-version if you want
#   to lock the version of Python being used.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not
#   install all needed dependencies.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains standard dependency locks and should be committed
#   unless you have specific requirements not to.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains standard dependency locks and should be committed
#   unless you have specific requirements not to.
#pdm.lock

# PEP 582; used by e.g. pdm when distributed packages are write-in-place
__pypackages__/

